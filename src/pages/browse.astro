---
import Layout from '../components/Layout.astro';
import FileList from '../components/FileList.astro';
import fs from 'node:fs';
import path from 'node:path';
import { LIBRARY_ROOT } from '../lib/db';
import { INDEX_PATH } from './api/scan';
import type { LibraryIndex } from './api/scan';

type Item = { name: string; path: string; type: 'directory' | 'file'; ext: string };

const q = (Astro.url.searchParams.get('q') ?? '').trim();
const isSearch = q.length > 0;

const requested = Astro.url.searchParams.get('path') ?? LIBRARY_ROOT;
const dirPath = path.resolve(requested);

// Redirect attempts to escape the library root back to its root
const safePath = dirPath.startsWith(LIBRARY_ROOT) ? dirPath : LIBRARY_ROOT;

const PAGE_SIZE = 100;
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1', 10));

let allItems: Item[] = [];
let items: Item[] = [];
let indexMissing = false;

try {
  const index: LibraryIndex = JSON.parse(fs.readFileSync(INDEX_PATH, 'utf8'));
  if (isSearch) {
    const qLower = q.toLowerCase();
    allItems = index.entries
      .filter(e => e.name.toLowerCase().includes(qLower))
      .sort((a, b) => {
        if (a.type !== b.type) return a.type === 'directory' ? -1 : 1;
        return a.name.localeCompare(b.name, undefined, { sensitivity: 'base' });
      });
  } else {
    allItems = index.entries
      .filter(e => path.dirname(e.path) === safePath)
      .sort((a, b) => {
        if (a.type !== b.type) return a.type === 'directory' ? -1 : 1;
        return a.name.localeCompare(b.name, undefined, { sensitivity: 'base' });
      });
  }
} catch {
  indexMissing = true;
}

items = allItems.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);

const totalPages = Math.ceil(allItems.length / PAGE_SIZE);
const browseBase = isSearch
  ? `/browse?q=${encodeURIComponent(q)}`
  : `/browse?path=${encodeURIComponent(safePath)}`;

// Build breadcrumb relative to LIBRARY_ROOT
const relative = path.relative(LIBRARY_ROOT, safePath);
const relParts = relative ? relative.split(path.sep) : [];
const breadcrumbs = relParts.map((part, i) => ({
  label: part,
  path: path.join(LIBRARY_ROOT, ...relParts.slice(0, i + 1)),
}));
const isAtRoot = safePath === LIBRARY_ROOT;
---

<Layout title={isSearch ? `Search: ${q}` : isAtRoot ? 'Library' : `Browse: ${path.basename(safePath)}`}>
  <div class="page-header">
    <nav class="breadcrumb">
      <a href="/browse" class="breadcrumb-item">Library</a>
      {!isSearch && breadcrumbs.map((crumb, i) => (
        <>
          <span class="breadcrumb-sep">›</span>
          {i < breadcrumbs.length - 1
            ? <a href={`/browse?path=${encodeURIComponent(crumb.path)}`} class="breadcrumb-item">{crumb.label}</a>
            : <span class="breadcrumb-item breadcrumb-current">{crumb.label}</span>
          }
        </>
      ))}
    </nav>
    <form class="search-form" action="/browse" method="get">
      <input class="search-input" type="search" name="q" value={q} placeholder="Search library…" autocomplete="off" />
      {!isSearch && <input type="hidden" name="path" value={safePath} />}
    </form>
  </div>

  {indexMissing && (
    <p class="search-result-count">Library not scanned yet. Go to <a href="/settings">Settings</a> to scan.</p>
  )}
  {isSearch && !indexMissing && (
    <p class="search-result-count">
      {allItems.length === 0 ? `No results for "${q}"` : `${allItems.length} result${allItems.length === 1 ? '' : 's'} for "${q}"`}
    </p>
  )}

  <FileList items={items} currentPath={safePath} libraryRoot={LIBRARY_ROOT} page={page} totalPages={totalPages} browseBase={browseBase} isSearch={isSearch} />
</Layout>
